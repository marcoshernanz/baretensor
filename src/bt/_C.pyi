"""BareTensor native extension (bootstrap)"""

from collections.abc import Sequence
import enum
from typing import overload


class DType(enum.Enum):
    float32 = 0

    int64 = 1

float32: DType = DType.float32

int64: DType = DType.int64

class Tensor:
    @property
    def shape(self) -> list[int]: ...

    @property
    def strides(self) -> list[int]: ...

    @property
    def dtype(self) -> DType: ...

    def ndim(self) -> int: ...

    def numel(self) -> int: ...

    @property
    def requires_grad(self) -> bool:
        """Whether this tensor tracks gradients in autograd."""

    @requires_grad.setter
    def requires_grad(self, arg: bool, /) -> None: ...

    def set_requires_grad(self, requires_grad: bool) -> Tensor: ...

    @property
    def is_leaf(self) -> bool: ...

    @property
    def grad(self) -> Tensor | None: ...

    def zero_grad(self) -> None: ...

    def detach(self) -> Tensor: ...

    def backward(self, gradient: Tensor | None = None) -> None: ...

    def is_contiguous(self) -> bool: ...

    def contiguous(self) -> Tensor: ...

    def to(self, dtype: DType) -> Tensor: ...

    def view(self, shape: Sequence[int]) -> Tensor: ...

    def reshape(self, shape: Sequence[int]) -> Tensor: ...

    def flatten(self, start_dim: int = 0, end_dim: int = -1) -> Tensor: ...

    def unsqueeze(self, dim: int) -> Tensor: ...

    def permute(self, dims: Sequence[int]) -> Tensor: ...

    def transpose(self, dim0: int, dim1: int) -> Tensor: ...

    def __getitem__(self, index: object | None) -> Tensor: ...

    def item(self) -> object: ...

    @property
    def T(self) -> Tensor: ...

    @property
    def mT(self) -> Tensor: ...

    def matmul(self, tensor2: Tensor) -> Tensor: ...

    def __matmul__(self, arg: Tensor, /) -> Tensor: ...

    def __neg__(self) -> Tensor: ...

    def __radd__(self, arg: float, /) -> Tensor: ...

    def __rsub__(self, arg: float, /) -> Tensor: ...

    def __rmul__(self, arg: float, /) -> Tensor: ...

    def __rtruediv__(self, arg: float, /) -> Tensor: ...

    @overload
    def __iadd__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __iadd__(self, arg: float, /) -> Tensor: ...

    @overload
    def __isub__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __isub__(self, arg: float, /) -> Tensor: ...

    @overload
    def __imul__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __imul__(self, arg: float, /) -> Tensor: ...

    @overload
    def __itruediv__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __itruediv__(self, arg: float, /) -> Tensor: ...

    def exp(self) -> Tensor: ...

    def log(self) -> Tensor: ...

    def tanh(self) -> Tensor: ...

    def softmax(self, dim: int) -> Tensor: ...

    def log_softmax(self, dim: int) -> Tensor: ...

    def sum(self, dim: object | None = None, keepdim: bool = False) -> Tensor: ...

    def mean(self, dim: object | None = None, keepdim: bool = False) -> Tensor: ...

    def max(self, dim: object | None = None, keepdim: bool = False) -> Tensor: ...

    def numpy(self) -> object: ...

    @overload
    def __add__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __add__(self, arg: float, /) -> Tensor: ...

    @overload
    def __sub__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __sub__(self, arg: float, /) -> Tensor: ...

    @overload
    def __mul__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __mul__(self, arg: float, /) -> Tensor: ...

    @overload
    def __truediv__(self, arg: Tensor, /) -> Tensor: ...

    @overload
    def __truediv__(self, arg: float, /) -> Tensor: ...

def full(shape: Sequence[int], fill_value: float, dtype: DType = DType.float32, requires_grad: bool = False) -> Tensor: ...

def zeros(shape: Sequence[int], dtype: DType = DType.float32, requires_grad: bool = False) -> Tensor: ...

def ones(shape: Sequence[int], dtype: DType = DType.float32, requires_grad: bool = False) -> Tensor: ...

def cat(tensors: Sequence[Tensor], dim: int = 0) -> Tensor: ...

def stack(tensors: Sequence[Tensor], dim: int = 0) -> Tensor: ...

def cross_entropy(input: Tensor, target: Tensor, ignore_index: int = -100, reduction: str = 'mean') -> Tensor: ...

def layer_norm(input: Tensor, normalized_shape: Sequence[int], weight: Tensor | None = None, bias: Tensor | None = None, eps: float = 9.999999747378752e-06) -> Tensor: ...

def embedding(input: Tensor, weight: Tensor) -> Tensor: ...

def tensor_from_numpy(array: object, dtype: DType, requires_grad: bool = False) -> Tensor: ...
